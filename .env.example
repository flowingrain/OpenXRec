# ============================================
# 智弈全域风险态势感知平台 - 环境变量示例配置
# ============================================
#
# 使用说明：
# 1. 复制此文件为 .env.local
# 2. 根据实际情况填写真实的配置值
# 3. .env.local 文件已被 .gitignore 忽略，不会提交到代码仓库
#
# ============================================

# ============================================
# Supabase 配置
# ============================================
# 1. 访问 https://supabase.com 创建项目
# 2. 在项目设置中找到 API 密钥
# 3. 将以下配置替换为你的项目信息

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# 仅用于「pnpm db:migrate」等直连 Postgres 执行 DDL；与上方 anon key 不同，必须含数据库密码
# 控制台：Project Settings → Database → Connection string → URI
# 也可用 DATABASE_URL 代替 SUPABASE_DB_URL
SUPABASE_DB_URL=postgresql://postgres:your_database_password@db.your-project.supabase.co:5432/postgres

# ============================================
# 运行环境：本地 vs Coze 托管（同一套代码）
# ============================================
# 不设置，或 OPENXREC_RUNTIME=local：本地 — createLLMClient 优先 DEEPSEEK_API_KEY，否则 Coze SDK；联网见下方「不设 WEB_SEARCH_PROVIDER」。
# OPENXREC_RUNTIME=coze：部署在 Coze 时设置 — 强制 LLM 与默认联网走 coze-coding-dev-sdk（忽略 DEEPSEEK，除非后续单独加覆盖项）。
# OPENXREC_RUNTIME=local
#
# ---------- OpenXRec：三种常用组合（环境开关）----------
# 1) 实验室内（省公网费用）：vLLM OpenAI 兼容（典型 SSH 隧道后本机 8010/8011）
#    OPENXREC_RUNTIME=local
#    OPENXREC_DEV_PROFILE=lab
#    OPENXREC_LAB_LLM_BASE_URL=http://127.0.0.1:8010/v1
#    OPENXREC_LAB_LLM_API_KEY=sk-your-key
#    OPENXREC_LAB_LLM_MODEL=/data/QWenModels/Qwen3.5-35B-A3B-FP8
#    OPENXREC_LAB_EMBEDDING_BASE_URL=http://127.0.0.1:8011/v1
#    OPENXREC_LAB_EMBEDDING_API_KEY=sk-your-key
#    OPENXREC_LAB_EMBEDDING_MODEL=/data/QWenModels/Qwen3-Embedding-4B
#    （可选）OPENXREC_LAB_LLM_TIMEOUT_MS=120000  OPENXREC_LAB_EMBEDDING_TIMEOUT_MS=60000
#    可选自建 BFF 根地址（业务里 joinLabApiUrl 用）：OPENXREC_LAB_API_BASE=http://192.168.x.x:8000
#    配置以上 LAB_LLM / LAB_EMBEDDING 后，应用内 createLLMClient / EmbeddingService 会优先走实验室，无需再配 DEEPSEEK / DashScope。
#
# 2) 不在实验室、本机开发（替代 Coze 的云端能力）：公网密钥 + 本地 Next
#    OPENXREC_RUNTIME=local
#    OPENXREC_DEV_PROFILE=cloud
#    （或不设 OPENXREC_DEV_PROFILE，默认即为 cloud）+ DEEPSEEK_API_KEY、EMBEDDING_SERVICE_API_KEY、TAVILY_API_KEY 等
#
# 3) 部署在 Coze 平台（最省事）
#    OPENXREC_RUNTIME=coze
#
# 本地子场景（仅 OPENXREC_RUNTIME=local 时读取；coze 下忽略）
# OPENXREC_DEV_PROFILE=cloud
# OPENXREC_LAB_API_BASE=

# ============================================
# 大语言模型配置
# ============================================
# 本地（OPENXREC_RUNTIME 非 coze）：若 OPENXREC_DEV_PROFILE=lab 且配齐 OPENXREC_LAB_LLM_*，主链路走实验室 vLLM；否则设置 DEEPSEEK_API_KEY 时走 DeepSeek。
# OPENXREC_RUNTIME=coze 时：始终走 Coze 平台 LLM，与本节 DEEPSEEK / LAB_LLM 无关。
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_BASE=https://api.deepseek.com

# 未配置 DeepSeek 时：Coze SDK 豆包（可被 LLM_MODEL 覆盖）
# 配置 DeepSeek 时：LLM_MODEL 可作为 DEEPSEEK_MODEL 的备选名称
# - OpenAI 兼容: deepseek-chat, deepseek-reasoner, gpt-4, ...
# - 豆包(Coze): doubao-seed-2-0-pro-260215

LLM_MODEL=gpt-4

# Agent 任务调度模型（可选，默认使用 LLM_MODEL）
# AGENT_SCHEDULER_MODEL=gpt-4

# ============================================
# Embedding 配置（本地推荐）
# ============================================
# 写入 pgvector 的维度（默认 1024 = Qwen3-Embedding-4B MRL 取前 1024 维；须与 Supabase vector(N) / RPC 一致）
# OPENXREC_PGVECTOR_DIMENSION=1024
#
# OPENXREC_DEV_PROFILE=lab 且配齐 OPENXREC_LAB_EMBEDDING_* 时，EmbeddingService 优先走实验室 vLLM（OpenAI /v1/embeddings）。
# 否则配置 EMBEDDING_SERVICE_API_KEY 后优先走 DashScope text-embedding-v4；
# 未配置时回退到 Coze SDK EmbeddingClient（本地可能出现 Invalid URL）。
#
# EMBEDDING_SERVICE_API_KEY=your_dashscope_api_key
# EMBEDDING_SERVICE_MODEL=text-embedding-v4
# EMBEDDING_SERVICE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding

# 推荐 API：是否在单次 LLM 请求内为每条结果生成「推荐理由」（默认开启；设为 0/false 可关闭以省时省 token）
# RECOMMENDATION_BATCH_LLM_EXPLANATIONS=true

# 推荐 API：最终返回条数上限，默认 10，可设 5～10
# RECOMMENDATION_MAX_ITEMS=10

# 推荐解释阶段（默认模板化，复用推理结果，减少 token）
# RECOMMENDATION_EXPLANATION_MODE=template   # template | llm
# RECOMMENDATION_USE_LLM_EXPLANATIONS=false  # 兼容旧开关，true 时启用 LLM 解释

# LangGraph 态势分析（/api/analyze-langgraph → executeAnalysis）
# 默认使用 compile 图单次 invoke；设为 true 回退旧版手写节点循环（含增量图谱逐步回调）
# USE_LEGACY_ANALYSIS_LOOP=false
# 意图解析后是否合并 IntelligentScheduler 与协调器编排（默认开启）
# USE_INTELLIGENT_SCHEDULER=true

# ============================================
# 域名配置（可选）
# ============================================
# 用于生成分享链接、WebSocket 连接地址等
# 如果不设置，将使用默认值

# NEXT_PUBLIC_DOMAIN=https://your-domain.com

# ============================================
# 联网检索（本地默认可脱离 Coze）
# ============================================
# 不设 WEB_SEARCH_PROVIDER 时：OPENXREC_RUNTIME=coze → 默认 coze；否则本地顺序为 TAVILY_API_KEY → tavily，否则 WEB_SEARCH_HTTP_URL → http，否则 none。
# WEB_SEARCH_PROVIDER=coze   # 显式使用 coze SearchClient（任意环境）
# WEB_SEARCH_PROVIDER=tavily
# WEB_SEARCH_PROVIDER=http
# WEB_SEARCH_PROVIDER=none   # 强制关闭联网检索
#
# 全渠道默认超时（毫秒，3s～120s）
# WEB_SEARCH_TIMEOUT_MS=45000
#
# Tavily：https://tavily.com — 注册后获取 API Key
# TAVILY_API_KEY=
# TAVILY_SEARCH_DEPTH=basic   # basic | advanced
# TAVILY_INCLUDE_ANSWER=false # true 时 summary 带简短综合答案
#
# 自定义 HTTP 网关
# WEB_SEARCH_HTTP_URL=https://your-api.example.com/search
# WEB_SEARCH_HTTP_SECRET=     # 可选：Authorization: Bearer …
# WEB_SEARCH_HTTP_HEADERS_JSON={"X-Custom":"value"}
# WEB_SEARCH_HTTP_RETRIES=2   # 失败重试次数（不含首次，默认 2）

# ============================================
# Coze SDK 配置（如果使用 Coze 平台）
# ============================================
# Coze SDK 的认证信息通常由平台自动注入
# 如果在其他平台部署，需要手动配置

# COZE_API_KEY=your_coze_api_key
# COZE_WORKSPACE_ID=your_workspace_id

# ============================================
# 对象存储配置（可选）
# ============================================
# 如果使用 S3 兼容对象存储，填写以下配置

# STORAGE_BUCKET_NAME=your-bucket-name
# STORAGE_REGION=your-region
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key

# ============================================
# Next.js 16 开发/构建（Turbopack 与 Windows 虚拟内存）
# ============================================
# 若出现 “An unexpected Turbopack error” 或 SWC 报错 “The paging file is too small”：
# 1) Windows：系统属性 → 高级 → 性能 → 高级 → 虚拟内存，适当增大分页文件。
# 2) 开发请执行 pnpm dev（已固定 --webpack）。勿使用裸命令 pnpm exec next dev，否则 Next 16 默认 Turbopack 易触发本错误。
# 3) 需先释放 5000 端口（Linux/Coze）：pnpm dev:bash。需 Turbopack：pnpm dev:turbo。构建默认 webpack：pnpm build；Turbopack 构建：pnpm build:turbo。

# ============================================
# 日志配置（可选）
# ============================================
# LOG_LEVEL=info
# LOG_DIR=/app/work/logs/bypass
