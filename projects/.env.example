# ============================================
# 智弈全域风险态势感知平台 - 环境变量示例配置
# ============================================
#
# 使用说明：
# 1. 复制此文件为 .env.local
# 2. 根据实际情况填写真实的配置值
# 3. .env.local 文件已被 .gitignore 忽略，不会提交到代码仓库
#
# ============================================

# ============================================
# Supabase 配置
# ============================================
# 1. 访问 https://supabase.com 创建项目
# 2. 在项目设置中找到 API 密钥
# 3. 将以下配置替换为你的项目信息

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# 仅用于「pnpm db:migrate」等直连 Postgres 执行 DDL；与上方 anon key 不同，必须含数据库密码
# 控制台：Project Settings → Database → Connection string → URI
# 也可用 DATABASE_URL 代替 SUPABASE_DB_URL
SUPABASE_DB_URL=postgresql://postgres:your_database_password@db.your-project.supabase.co:5432/postgres

# ============================================
# 大语言模型配置
# ============================================
# 若设置 DEEPSEEK_API_KEY，主链路（LangGraph /chat / 人格等）将走 DeepSeek OpenAPI，不再用 Coze LLM。
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_BASE=https://api.deepseek.com

# 未配置 DeepSeek 时：Coze SDK 豆包（可被 LLM_MODEL 覆盖）
# 配置 DeepSeek 时：LLM_MODEL 可作为 DEEPSEEK_MODEL 的备选名称
# - OpenAI 兼容: deepseek-chat, deepseek-reasoner, gpt-4, ...
# - 豆包(Coze): doubao-seed-2-0-pro-260215

LLM_MODEL=gpt-4

# Agent 任务调度模型（可选，默认使用 LLM_MODEL）
# AGENT_SCHEDULER_MODEL=gpt-4

# 推荐 API：是否在单次 LLM 请求内为每条结果生成「推荐理由」（默认开启；设为 0/false 可关闭以省时省 token）
# RECOMMENDATION_BATCH_LLM_EXPLANATIONS=true

# 推荐 API：最终返回条数上限，默认 10，可设 5～10
# RECOMMENDATION_MAX_ITEMS=10

# ============================================
# 域名配置（可选）
# ============================================
# 用于生成分享链接、WebSocket 连接地址等
# 如果不设置，将使用默认值

# NEXT_PUBLIC_DOMAIN=https://your-domain.com

# ============================================
# 联网检索（coze / tavily / http / none）
# ============================================
# WEB_SEARCH_PROVIDER=coze   # 默认：coze-coding-dev-sdk SearchClient
# WEB_SEARCH_PROVIDER=tavily # 直连 Tavily（需 TAVILY_API_KEY）
# WEB_SEARCH_PROVIDER=http   # 自定义：POST 到 WEB_SEARCH_HTTP_URL，返回 { web_items } 或 { results }
# WEB_SEARCH_PROVIDER=none   # 关闭联网检索（空结果）
#
# 全渠道默认超时（毫秒，3s～120s）
# WEB_SEARCH_TIMEOUT_MS=45000
#
# Tavily：https://tavily.com — 注册后获取 API Key
# TAVILY_API_KEY=
# TAVILY_SEARCH_DEPTH=basic   # basic | advanced
# TAVILY_INCLUDE_ANSWER=false # true 时 summary 带简短综合答案
#
# 自定义 HTTP 网关
# WEB_SEARCH_HTTP_URL=https://your-api.example.com/search
# WEB_SEARCH_HTTP_SECRET=     # 可选：Authorization: Bearer …
# WEB_SEARCH_HTTP_HEADERS_JSON={"X-Custom":"value"}
# WEB_SEARCH_HTTP_RETRIES=2   # 失败重试次数（不含首次，默认 2）

# ============================================
# Coze SDK 配置（如果使用 Coze 平台）
# ============================================
# Coze SDK 的认证信息通常由平台自动注入
# 如果在其他平台部署，需要手动配置

# COZE_API_KEY=your_coze_api_key
# COZE_WORKSPACE_ID=your_workspace_id

# ============================================
# 对象存储配置（可选）
# ============================================
# 如果使用 S3 兼容对象存储，填写以下配置

# STORAGE_BUCKET_NAME=your-bucket-name
# STORAGE_REGION=your-region
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key

# ============================================
# 日志配置（可选）
# ============================================
# LOG_LEVEL=info
# LOG_DIR=/app/work/logs/bypass
