# ============================================
# 智弈全域风险态势感知平台 - 环境变量示例配置
# ============================================
#
# 使用说明：
# 1. 复制此文件为 .env.local
# 2. 根据实际情况填写真实的配置值
# 3. .env.local 文件已被 .gitignore 忽略，不会提交到代码仓库
#
# ============================================

# ============================================
# Supabase 配置
# ============================================
# 1. 访问 https://supabase.com 创建项目
# 2. 在项目设置中找到 API 密钥
# 3. 将以下配置替换为你的项目信息

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_DB_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres

# ============================================
# 大语言模型配置
# ============================================
# 支持的模型：
# - OpenAI: gpt-4, gpt-3.5-turbo
# - Claude: claude-3-opus, claude-3-sonnet, claude-3-haiku
# - Doubao: doubao-seed-2-0-pro-260215
# - 其他兼容 OpenAI API 的模型

LLM_MODEL=gpt-4

# Agent 任务调度模型（可选，默认使用 LLM_MODEL）
# AGENT_SCHEDULER_MODEL=gpt-4

# ============================================
# 域名配置（可选）
# ============================================
# 用于生成分享链接、WebSocket 连接地址等
# 如果不设置，将使用默认值

# NEXT_PUBLIC_DOMAIN=https://your-domain.com

# ============================================
# Coze SDK 配置（如果使用 Coze 平台）
# ============================================
# Coze SDK 的认证信息通常由平台自动注入
# 如果在其他平台部署，需要手动配置

# COZE_API_KEY=your_coze_api_key
# COZE_WORKSPACE_ID=your_workspace_id

# ============================================
# 对象存储配置（可选）
# ============================================
# 如果使用 S3 兼容对象存储，填写以下配置

# STORAGE_BUCKET_NAME=your-bucket-name
# STORAGE_REGION=your-region
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key

# ============================================
# 日志配置（可选）
# ============================================
# LOG_LEVEL=info
# LOG_DIR=/app/work/logs/bypass
